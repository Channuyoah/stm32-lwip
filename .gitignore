# --- 编译输出 (Build Artifacts) ---
# CMake 构建目录
build/
# 常见的构建输出目录
Debug/
Release/
# 编译器生成文件
*.o
*.d
*.elf
*.bin
*.hex
*.map
*.lst
*.a
*.su

# --- STM32CubeMX 生成文件 ---
# CubeMX 生成的代码索引目录，每次打开软件会自动刷新
SI/
project/
# 用户界面状态文件，包含本地路径信息
*.uvguix.*
*.uvgui.*
# 包含本地路径的工程文件，仅用于个人导入，不应提交
.mxproject

# --- IDE 与编辑器配置 (IDE & Editor Config) ---
# 忽略VSCode的本地配置，每个开发者可以有自己的设置
.vscode/
# 忽略Eclipse/CubeIDE的项目文件
.settings/
*.cproject
*.project

# --- 调试与日志文件 (Debug & Log Files) ---
# J-Link 调试日志
JLinkLog.txt
*.jlink
*.dbgconf
# 其他日志文件
*.log

# --- 操作系统生成文件 (OS Generated Files) ---
# macOS 文件夹属性文件
.DS_Store
# Windows 缩略图文件
Thumbs.db
# 临时备份文件
*.bak
*~

# --- Keil MDK (uVision) 特定文件 ---
*.uvoptx          # 用户调试/布局配置
*.uvopt
*.scvd
*.crf            # 编译浏览信息
*.axf            # 可执行文件
*.htm            # 编译输出报告
*.lnp            # 链接器临时文件
*.dep            # 依赖文件
*.build_log.htm  # 构建日志
# 精确忽略 MDK-ARM 目录下的所有生成文件和临时目录
SixAxisSTM32H723/MDK-ARM/.cmsis/
SixAxisSTM32H723/MDK-ARM/.eide/
SixAxisSTM32H723/MDK-ARM/RTE/
SixAxisSTM32H723/MDK-ARM/RTE_Components.h
SixAxisSTM32H723/MDK-ARM/*.uvoptx
SixAxisSTM32H723/MDK-ARM/*.uvopt
SixAxisSTM32H723/MDK-ARM/*.scvd
SixAxisSTM32H723/MDK-ARM/*.BAT
SixAxisSTM32H723/MDK-ARM/*.code-workspace
SixAxisSTM32H723/MDK-ARM/SixAxisSTM32H723/*.crf
SixAxisSTM32H723/MDK-ARM/SixAxisSTM32H723/*.htm
SixAxisSTM32H723/MDK-ARM/SixAxisSTM32H723/*.axf
SixAxisSTM32H723/MDK-ARM/SixAxisSTM32H723/*.dep
SixAxisSTM32H723/MDK-ARM/SixAxisSTM32H723/*.lnp
SixAxisSTM32H723/MDK-ARM/SixAxisSTM32H723/*.build_log.htm

# --- 自动生成的中间目录 ---
RTE/             # Runtime Environment 自动生成
_RTE/
.cmsis/          # CMSIS 设备文件副本（通常不应入仓）
.eide/           # 某些插件/工具的本地配置
.clangd          # Clangd 语言服务器缓存

# --- 其他 IDE 本地文件 ---
*.code-workspace # VS Code 工作区（个人）
*.BAT            # 临时批处理文件

# --- 已跟踪但未覆盖的固件输出（与上面已有规则不冲突）---
*.sct            # 链接脚本，若为自动生成则忽略
