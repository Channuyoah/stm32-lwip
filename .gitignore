# --- 编译输出 (Build Artifacts) ---
# CMake 构建目录
build/
# 常见的构建输出目录
Debug/
Release/
# 编译器生成文件
*.o
*.d
*.elf
*.bin
*.hex
*.map
*.lst
*.a
*.su

# --- STM32CubeMX 生成文件 ---
# CubeMX 生成的代码索引目录，每次打开软件会自动刷新
SI/
project/
# 用户界面状态文件，包含本地路径信息
*.uvguix.*
*.uvgui.*
# 包含本地路径的工程文件，仅用于个人导入，不应提交
.mxproject

# --- IDE 与编辑器配置 (IDE & Editor Config) ---
# 忽略VSCode的本地配置，每个开发者可以有自己的设置
.vscode/
# 忽略Eclipse/CubeIDE的项目文件
.settings/
*.cproject
*.project

# --- 调试与日志文件 (Debug & Log Files) ---
# J-Link 调试日志
JLinkLog.txt
*.jlink
*.dbgconf
# 其他日志文件
*.log

# --- 操作系统生成文件 (OS Generated Files) ---
# macOS 文件夹属性文件
.DS_Store
# Windows 缩略图文件
Thumbs.db
# 临时备份文件
*.bak
*~
